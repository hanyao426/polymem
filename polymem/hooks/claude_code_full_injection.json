{
  "description": "PolyMem Claude Code hooks — FULL INJECTION (collect + complete $PMEM block at SessionStart)",
  "_note": "Heaviest variant. Injects ~3000 tokens at every session start, including last summary detail. Use only if you really need rich context up front.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{POLYMEM_BIN}} hook context",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{POLYMEM_BIN}} hook session-init",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{POLYMEM_BIN}} hook observation",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{POLYMEM_BIN}} hook summarize",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{POLYMEM_BIN}} hook session-complete",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
