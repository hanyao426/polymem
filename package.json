{
  "name": "@ccc/polymem",
  "version": "0.1.0",
  "description": "Cross-tool memory system for Claude Code, Codex, Cursor, Cline. Auto-collect tool calls, extract structured observations, search via FTS5+vector, share across clients.",
  "type": "module",
  "bin": {
    "polymem": "./bin/polymem.mjs"
  },
  "files": [
    "bin",
    "collectors/base",
    "collectors/claude-code",
    "collectors/codex",
    "mcp-server",
    "scripts/install-claude-code.sh",
    "scripts/uninstall-claude-code.sh",
    "scripts/start-engine.sh",
    "scripts/start-codex-watcher.sh",
    "scripts/daily-report.sh",
    "engine",
    "pyproject.toml",
    "README.md",
    "API.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "mcp": "tsx mcp-server/server.ts",
    "codex": "tsx collectors/codex/watcher.ts",
    "hook": "tsx collectors/claude-code/hook-handler.ts",
    "prepublishOnly": "node bin/polymem.mjs --doctor"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "tsx": "^4.19.0"
  },
  "keywords": [
    "claude-code",
    "codex",
    "memory",
    "mcp",
    "cross-tool",
    "observability",
    "agent-memory"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  }
}
