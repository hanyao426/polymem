{
  "description": "PolyMem Claude Code hooks — HYBRID (collection + lightweight $PMEM index injection + MCP for details)",
  "_note": "SessionStart injects only titles + IDs from the last 3 days (~300-500 tokens). Detailed observation bodies, summaries, and timeline are fetched on demand via MCP tools (memory_get / memory_search / memory_recall_full). Tune window via env: POLYMEM_LITE_DAYS=7 POLYMEM_LITE_MAX=50.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" context-lite",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" session-init",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" observation",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" summarize",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" session-complete",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
