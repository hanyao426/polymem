{
  "description": "PolyMem Claude Code collector hooks — COLLECTION ONLY (no session injection)",
  "_note": "SessionStart hook intentionally omitted. Context is NOT injected into sessions. Use MCP tool memory_context or hooks-with-injection.json to enable injection once you trust the data.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" session-init",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" observation",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" summarize",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${POLYMEM_ROOT:-$HOME/demo/polymem}/collectors/claude-code/hook-handler.ts\" session-complete",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
